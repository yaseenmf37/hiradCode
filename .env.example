# ─────────────────────────────────────────────────────────
# همه این‌ها روی تیر رایگان کار می‌کنند. چیزی خریدنی نیست.
# این فایل را به .env.local کپی کنید و مقادیر را پر کنید.
# ─────────────────────────────────────────────────────────

# ── پنل مدیریت (لازم) ───────────────────────────────────
# رمزی که با آن وارد /admin می‌شوید.
ADMIN_PASSWORD=

# کلید امضای کوکی نشست. یک رشته تصادفی طولانی.
# ساخت: openssl rand -hex 32
AUTH_SECRET=

# ── پایگاه داده (لازم برای انتشار) ──────────────────────
# Neon Postgres — رایگان. در داشبورد Vercel:
#   Storage → Create Database → Neon → Connect
# بعد از اتصال، Vercel این متغیر را خودش اضافه می‌کند.
#
# اگر خالی باشد، در حالت توسعه محلی داده‌ها در پوشه .data/
# ذخیره می‌شوند و روی Vercel سایت فقط‌خواندنی می‌شود.
DATABASE_URL=

# ── آپلود تصویر (اختیاری) ───────────────────────────────
# Vercel Blob — رایگان تا ۱ گیگابایت. در داشبورد Vercel:
#   Storage → Create → Blob → Connect
# بدون این متغیر، آپلود کار نمی‌کند ولی می‌توانید
# آدرس تصویر را دستی در پنل وارد کنید.
BLOB_READ_WRITE_TOKEN=

# ── آدرس سایت (اختیاری) ─────────────────────────────────
# برای sitemap و تگ‌های Open Graph. بدون اسلش آخر.
NEXT_PUBLIC_SITE_URL=https://hiradcode.ir
